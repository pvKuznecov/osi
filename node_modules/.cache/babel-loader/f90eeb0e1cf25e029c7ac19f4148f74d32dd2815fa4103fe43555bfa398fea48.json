{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport \"core-js/modules/es.iterator.find.js\";\nimport \"core-js/modules/es.iterator.map.js\";\nimport AutorizationArea from './components/os/AutorizationArea/AutorizationArea.vue';\nimport DesktopArea from './components/os/DesktopArea/DesktopArea.vue';\nimport TaskBar from './components/os/TaskBar/TaskBar.vue';\nimport SimpleWindow from './components/os/SimpleWindow/SimpleWindow.vue';\nimport { usersTable, IDBWindows, activeWindowId } from './idb/db';\nimport { appsConfig } from './config/applications';\nexport default {\n  name: 'App',\n  components: {\n    AutorizationArea,\n    DesktopArea,\n    TaskBar,\n    SimpleWindow\n  },\n  data() {\n    return {\n      isAutorized: false,\n      USERID: null,\n      USER: {}\n    };\n  },\n  computed: {\n    IDBWindows() {\n      return IDBWindows.value;\n    },\n    // Сортируем окна по zIndex для правильного отображения\n    sortedWindows() {\n      if (!this.IDBWindows) {\n        return [];\n      } else {\n        // Фильтруем свернутые окна - они не отображаются на рабочем столе\n        const visibleWindows = this.IDBWindows.filter(w => !w.isMinimized);\n        // Сортируем по zIndex (от меньшего к большему)\n        return [...visibleWindows].sort((a, b) => (a.zIndex || 0) - (b.zIndex || 0));\n      }\n    }\n  },\n  methods: {\n    // проверка на \"это активный элемент\"\n    isActiveElem(windowId) {\n      return windowId === activeWindowId.value;\n    },\n    async closeWindow(windowId) {\n      if (this.USERID && usersTable) {\n        try {\n          await usersTable.closeComplWindow(this.USERID, windowId);\n          await usersTable.windows.reupdate(this.USERID);\n        } catch (error) {\n          console.error('Error closing window:', error);\n        }\n      }\n    },\n    async minimizeWindow(windowId) {\n      if (this.USERID && usersTable) {\n        try {\n          await usersTable.windows.minimize(this.USERID, windowId);\n          await usersTable.windows.reupdate(this.USERID);\n        } catch (error) {\n          console.error('Error minimizing window:', error);\n        }\n      }\n    },\n    async toggleMaximizeWindow(windowId) {\n      if (this.USERID && usersTable) {\n        try {\n          // Получаем текущее состояние окна\n          const windows = IDBWindows.value || [];\n          const window = windows.find(w => w.id === windowId);\n          if (window) {\n            // Переключаем состояние максимизации\n            window.isMaximized = !window.isMaximized;\n\n            // Обновляем в БД\n            const user = await usersTable.getbyId(this.USERID);\n            const updatedWindows = windows.map(w => w.id === windowId ? window : w);\n            await usersTable.save({\n              ...user,\n              systemconfig: {\n                ...user.systemconfig,\n                windows: updatedWindows\n              }\n            });\n            await usersTable.windows.reupdate(this.USERID);\n          }\n        } catch (error) {\n          console.error('Error toggling maximize window:', error);\n        }\n      }\n    },\n    async activateWindow(windowId) {\n      if (this.USERID && usersTable) {\n        try {\n          // Активируем окно (обновляет zIndex и снимает свернутость)\n          await usersTable.windows.activate(this.USERID, windowId);\n          // Обновляем список окон\n          await usersTable.windows.reupdate(this.USERID);\n        } catch (error) {\n          console.error('Error activating window:', error);\n        }\n      } else {\n        console.log('Cannot activate: USERID or usersTable missing');\n      }\n    },\n    async selectUser(userId) {\n      this.USERID = userId;\n      if (usersTable) {\n        try {\n          // Загружаем пользователя\n          this.USER = await usersTable.getbyId(userId);\n          // Обновляем список окон\n          await usersTable.windows.reupdate(userId);\n        } catch (error) {\n          console.error('Error loading user data:', error);\n        }\n      }\n      this.isAutorized = true;\n    },\n    // Метод для восстановления окна из свернутого состояния\n    async restoreWindow(windowId) {\n      if (this.USERID && usersTable) {\n        try {\n          if (usersTable.windows.restore) {\n            await usersTable.windows.restore(this.USERID, windowId);\n          } else {\n            await usersTable.windows.activate(this.USERID, windowId);\n          }\n          await usersTable.windows.reupdate(this.USERID);\n        } catch (error) {\n          console.error('Error restoring window:', error);\n        }\n      }\n    },\n    // открыть файл из IDB в конкретном приложении\n    async openFileApp(inpData) {\n      if (!this.USERID) throw new Error('User ID required');\n      if (!inpData) throw new Error('File data required');\n      console.log('||openFileApp (inpData):', inpData);\n      try {\n        const app = appsConfig.getAppById(inpData.app);\n\n        // Проверяем существующее окно\n        const existWindow_byConfig = await usersTable.windows.getWindow_byConfig(this.USERID, app);\n        if (existWindow_byConfig) {\n          // Окно существует - активируем его\n          await usersTable.windows.activate(this.USERID, existWindow_byConfig.id);\n\n          // !!! ВАЖНО: обновляем idbfile у существующего окна\n          const user = await usersTable.getbyId(this.USERID);\n          const windows = user?.systemconfig?.windows || [];\n\n          // Находим наше окно и обновляем в нем idbfile\n          const updatedWindows = windows.map(w => {\n            if (w.id === existWindow_byConfig.id) {\n              return {\n                ...w,\n                idbfile: inpData.file // Сохраняем файл в окне\n              };\n            }\n            return w;\n          });\n\n          // Сохраняем обновленные окна\n          await usersTable.save({\n            ...user,\n            systemconfig: {\n              ...user.systemconfig,\n              windows: updatedWindows,\n              activeWindowId: existWindow_byConfig.id\n            }\n          });\n          await usersTable.windows.reupdate(this.USERID);\n        } else {\n          // Создаем новое окно с файлом\n          console.log('Создаем новое окно с файлом:', inpData.file);\n          await usersTable.windows.create(this.USERID, {\n            ...app,\n            idbfile: inpData.file,\n            // Передаем файл в окно\n            isMinimized: false\n          });\n        }\n      } catch (error) {\n        console.error('openFileApp:', error);\n        this.showError(`Error in openFileApp(): ${error.message}`);\n      }\n    }\n  }\n};","map":{"version":3,"names":["AutorizationArea","DesktopArea","TaskBar","SimpleWindow","usersTable","IDBWindows","activeWindowId","appsConfig","name","components","data","isAutorized","USERID","USER","computed","value","sortedWindows","visibleWindows","filter","w","isMinimized","sort","a","b","zIndex","methods","isActiveElem","windowId","closeWindow","closeComplWindow","windows","reupdate","error","console","minimizeWindow","minimize","toggleMaximizeWindow","window","find","id","isMaximized","user","getbyId","updatedWindows","map","save","systemconfig","activateWindow","activate","log","selectUser","userId","restoreWindow","restore","openFileApp","inpData","Error","app","getAppById","existWindow_byConfig","getWindow_byConfig","idbfile","file","create","showError","message"],"sources":["/home/kup/my_projects/vue/osi/src/App.vue"],"sourcesContent":["<template>\n    <AutorizationArea v-if=\"!isAutorized\" @selectUser=\"selectUser\" />\n    <div v-if=\"isAutorized\" class=\"webos\">\n        <DesktopArea :USERID=\"USERID\">\n            <SimpleWindow \n                v-for=\"window in sortedWindows\"\n                :key=\"window.id\"\n                :windowId=\"window.id\"\n                :title=\"window.label\"\n                :appName=\"window.name\"\n                :contentApp=\"window.contentApp\"\n                :icon=\"window.icon\"\n                :iconclass=\"window.iconclass\"\n                :defWidth=\"window.defWidth\"\n                :defHeight=\"window.defHeight\"\n                :isMinimized=\"window.isMinimized\"\n                :isActive=\"isActiveElem(window.id)\"\n                :isMaximized=\"window.isMaximized\"\n                :zIndex=\"window.zIndex\"\n                :resizable=\"window.resizable\"\n                :canMinimize=\"window.canMinimize\"\n                :USERID=\"USERID\"\n                :positionx=\"window.positionx\"\n                :positiony=\"window.positiony\"\n                :idbFile=\"window.idbfile\"\n                \n                @close=\"closeWindow\"\n                @minimize=\"minimizeWindow\"\n                @toggleMaximize=\"toggleMaximizeWindow\"\n                @focus=\"activateWindow\"\n                @mainopenfileapp=\"openFileApp\"\n            />\n        </DesktopArea>\n        <TaskBar :USERID=\"USERID\" />\n    </div>\n</template>\n<style src=\"./styles/global.css\"></style>\n<script>\nimport AutorizationArea from './components/os/AutorizationArea/AutorizationArea.vue';\nimport DesktopArea from './components/os/DesktopArea/DesktopArea.vue';\nimport TaskBar from './components/os/TaskBar/TaskBar.vue';\nimport SimpleWindow from './components/os/SimpleWindow/SimpleWindow.vue';\nimport { usersTable, IDBWindows, activeWindowId } from './idb/db';\nimport { appsConfig } from './config/applications';\n\nexport default {\n    name: 'App',\n\n    components: {\n        AutorizationArea,\n        DesktopArea,\n        TaskBar,\n        SimpleWindow\n    },\n\n    data() {\n        return {\n            isAutorized: false,\n            USERID: null,\n            USER: {},\n        }\n    },\n\n    computed: {\n        IDBWindows() { return IDBWindows.value; },\n        // Сортируем окна по zIndex для правильного отображения\n        sortedWindows() {\n            if (!this.IDBWindows) {\n                return [];\n            } else {\n                // Фильтруем свернутые окна - они не отображаются на рабочем столе\n                const visibleWindows = this.IDBWindows.filter(w => !w.isMinimized);            \n                // Сортируем по zIndex (от меньшего к большему)\n                return [...visibleWindows].sort((a, b) => (a.zIndex || 0) - (b.zIndex || 0));\n            }\n        },\n    },\n\n    methods: {\n        // проверка на \"это активный элемент\"\n        isActiveElem(windowId) { return windowId === activeWindowId.value; },\n\n        async closeWindow(windowId) {            \n            if (this.USERID && usersTable) {\n                try {\n                    await usersTable.closeComplWindow(this.USERID, windowId);\n                    await usersTable.windows.reupdate(this.USERID);\n                } catch (error) {\n                    console.error('Error closing window:', error);\n                }\n            }\n        },\n    \n        async minimizeWindow(windowId) {            \n            if (this.USERID && usersTable) {\n                try {\n                    await usersTable.windows.minimize(this.USERID, windowId);\n                    await usersTable.windows.reupdate(this.USERID);\n                } catch (error) {\n                    console.error('Error minimizing window:', error);\n                }\n            }\n        },\n    \n        async toggleMaximizeWindow(windowId) {            \n            if (this.USERID && usersTable) {\n                try {\n                    // Получаем текущее состояние окна\n                    const windows = IDBWindows.value || [];\n                    const window = windows.find(w => w.id === windowId);\n                    \n                    if (window) {\n                        // Переключаем состояние максимизации\n                        window.isMaximized = !window.isMaximized;\n                        \n                        // Обновляем в БД\n                        const user = await usersTable.getbyId(this.USERID);\n                        const updatedWindows = windows.map(w => \n                            w.id === windowId ? window : w\n                        );\n                        \n                        await usersTable.save({\n                            ...user,\n                            systemconfig: {\n                                ...user.systemconfig,\n                                windows: updatedWindows\n                            }\n                        });\n                        \n                        await usersTable.windows.reupdate(this.USERID);\n                    }\n                } catch (error) {\n                    console.error('Error toggling maximize window:', error);\n                }\n            }\n        },\n    \n        async activateWindow(windowId) {            \n            if (this.USERID && usersTable) { \n                try {\n                    // Активируем окно (обновляет zIndex и снимает свернутость)\n                    await usersTable.windows.activate(this.USERID, windowId);\n                    // Обновляем список окон\n                    await usersTable.windows.reupdate(this.USERID);\n                } catch (error) {\n                    console.error('Error activating window:', error);\n                }\n            } else {\n                console.log('Cannot activate: USERID or usersTable missing');\n            }\n        },\n\n        async selectUser(userId) {\n            this.USERID = userId;\n\n            if (usersTable) {\n                try {\n                    // Загружаем пользователя\n                    this.USER = await usersTable.getbyId(userId);\n                    // Обновляем список окон\n                    await usersTable.windows.reupdate(userId);\n                } catch (error) {\n                    console.error('Error loading user data:', error);\n                }\n            }\n            \n            this.isAutorized = true;\n        },\n\n        // Метод для восстановления окна из свернутого состояния\n        async restoreWindow(windowId) {            \n            if (this.USERID && usersTable) {\n                try {\n                    if (usersTable.windows.restore) {\n                        await usersTable.windows.restore(this.USERID, windowId);\n                    } else {\n                        await usersTable.windows.activate(this.USERID, windowId);\n                    }\n\n                    await usersTable.windows.reupdate(this.USERID);\n                } catch (error) {\n                    console.error('Error restoring window:', error);\n                }\n            }\n        },\n\n        // открыть файл из IDB в конкретном приложении\n        async openFileApp(inpData) {\n            if (!this.USERID) throw new Error('User ID required');\n            if (!inpData) throw new Error('File data required');\n\n            console.log('||openFileApp (inpData):', inpData);\n            try {\n                const app = appsConfig.getAppById(inpData.app);\n                \n                // Проверяем существующее окно\n                const existWindow_byConfig = await usersTable.windows.getWindow_byConfig(this.USERID, app);\n                \n                if (existWindow_byConfig) {\n                    // Окно существует - активируем его\n                    await usersTable.windows.activate(this.USERID, existWindow_byConfig.id);\n                    \n                    // !!! ВАЖНО: обновляем idbfile у существующего окна\n                    const user = await usersTable.getbyId(this.USERID);\n                    const windows = user?.systemconfig?.windows || [];\n                    \n                    // Находим наше окно и обновляем в нем idbfile\n                    const updatedWindows = windows.map(w => {\n                        if (w.id === existWindow_byConfig.id) {\n                            return {\n                                ...w,\n                                idbfile: inpData.file // Сохраняем файл в окне\n                            };\n                        }\n                        return w;\n                    });\n                    \n                    // Сохраняем обновленные окна\n                    await usersTable.save({\n                        ...user,\n                        systemconfig: {\n                            ...user.systemconfig,\n                            windows: updatedWindows,\n                            activeWindowId: existWindow_byConfig.id\n                        }\n                    });\n                    \n                    await usersTable.windows.reupdate(this.USERID);\n                } else {\n                    // Создаем новое окно с файлом\n                    console.log('Создаем новое окно с файлом:', inpData.file);\n                    await usersTable.windows.create(this.USERID, { \n                        ...app,\n                        idbfile: inpData.file, // Передаем файл в окно\n                        isMinimized: false\n                    });\n                }\n            } catch (error) {\n                console.error('openFileApp:', error);\n                this.showError(`Error in openFileApp(): ${error.message}`);\n            }\n        }\n    },\n}\n</script>\n\n<style>\n.webos {\n    width: 100vw;\n    height: 100vh;\n    overflow: hidden;\n    position: relative;\n    background: #1a1a1a;\n}\n</style>"],"mappings":";;;;AAsCA,OAAOA,gBAAe,MAAO,uDAAuD;AACpF,OAAOC,WAAU,MAAO,6CAA6C;AACrE,OAAOC,OAAM,MAAO,qCAAqC;AACzD,OAAOC,YAAW,MAAO,+CAA+C;AACxE,SAASC,UAAU,EAAEC,UAAU,EAAEC,cAAa,QAAS,UAAU;AACjE,SAASC,UAAS,QAAS,uBAAuB;AAElD,eAAe;EACXC,IAAI,EAAE,KAAK;EAEXC,UAAU,EAAE;IACRT,gBAAgB;IAChBC,WAAW;IACXC,OAAO;IACPC;EACJ,CAAC;EAEDO,IAAIA,CAAA,EAAG;IACH,OAAO;MACHC,WAAW,EAAE,KAAK;MAClBC,MAAM,EAAE,IAAI