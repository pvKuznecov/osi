{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport \"core-js/modules/es.iterator.find.js\";\nimport \"core-js/modules/es.iterator.map.js\";\nimport \"core-js/modules/es.json.stringify.js\";\nimport \"core-js/modules/esnext.json.parse.js\";\nimport AutorizationArea from './components/os/AutorizationArea/AutorizationArea.vue';\nimport DesktopArea from './components/os/DesktopArea/DesktopArea.vue';\nimport TaskBar from './components/os/TaskBar/TaskBar.vue';\nimport SimpleWindow from './components/os/SimpleWindow/SimpleWindow.vue';\nimport { usersTable, IDBWindows, activeWindowId } from './idb/db';\nimport { appsConfig } from './config/applications';\nexport default {\n  name: 'App',\n  components: {\n    AutorizationArea,\n    DesktopArea,\n    TaskBar,\n    SimpleWindow\n  },\n  data() {\n    return {\n      isAutorized: false,\n      USERID: null,\n      USER: {}\n    };\n  },\n  computed: {\n    IDBWindows() {\n      return IDBWindows.value;\n    },\n    // Сортируем окна по zIndex для правильного отображения\n    sortedWindows() {\n      if (!this.IDBWindows) {\n        return [];\n      } else {\n        // Фильтруем свернутые окна - они не отображаются на рабочем столе\n        const visibleWindows = this.IDBWindows.filter(w => !w.isMinimized);\n        // Сортируем по zIndex (от меньшего к большему)\n        return [...visibleWindows].sort((a, b) => (a.zIndex || 0) - (b.zIndex || 0));\n      }\n    }\n  },\n  methods: {\n    // проверка на \"это активный элемент\"\n    isActiveElem(windowId) {\n      return windowId === activeWindowId.value;\n    },\n    async closeWindow(windowId) {\n      if (this.USERID && usersTable) {\n        try {\n          await usersTable.closeComplWindow(this.USERID, windowId);\n          await usersTable.windows.reupdate(this.USERID);\n        } catch (error) {\n          console.error('Error closing window:', error);\n        }\n      }\n    },\n    async minimizeWindow(windowId) {\n      if (this.USERID && usersTable) {\n        try {\n          await usersTable.windows.minimize(this.USERID, windowId);\n          await usersTable.windows.reupdate(this.USERID);\n        } catch (error) {\n          console.error('Error minimizing window:', error);\n        }\n      }\n    },\n    async toggleMaximizeWindow(windowId) {\n      if (this.USERID && usersTable) {\n        try {\n          // Получаем текущее состояние окна\n          const windows = IDBWindows.value || [];\n          const window = windows.find(w => w.id === windowId);\n          if (window) {\n            // Переключаем состояние максимизации\n            window.isMaximized = !window.isMaximized;\n\n            // Обновляем в БД\n            const user = await usersTable.getbyId(this.USERID);\n            const updatedWindows = windows.map(w => w.id === windowId ? window : w);\n            await usersTable.save({\n              ...user,\n              systemconfig: {\n                ...user.systemconfig,\n                windows: updatedWindows\n              }\n            });\n            await usersTable.windows.reupdate(this.USERID);\n          }\n        } catch (error) {\n          console.error('Error toggling maximize window:', error);\n        }\n      }\n    },\n    async activateWindow(windowId) {\n      if (this.USERID && usersTable) {\n        try {\n          // Активируем окно (обновляет zIndex и снимает свернутость)\n          await usersTable.windows.activate(this.USERID, windowId);\n          // Обновляем список окон\n          await usersTable.windows.reupdate(this.USERID);\n        } catch (error) {\n          console.error('Error activating window:', error);\n        }\n      } else {\n        console.log('Cannot activate: USERID or usersTable missing');\n      }\n    },\n    async selectUser(userId) {\n      this.USERID = userId;\n      if (usersTable) {\n        try {\n          // Загружаем пользователя\n          this.USER = await usersTable.getbyId(userId);\n          // Обновляем список окон\n          await usersTable.windows.reupdate(userId);\n        } catch (error) {\n          console.error('Error loading user data:', error);\n        }\n      }\n      this.isAutorized = true;\n    },\n    // Метод для восстановления окна из свернутого состояния\n    async restoreWindow(windowId) {\n      if (this.USERID && usersTable) {\n        try {\n          if (usersTable.windows.restore) {\n            await usersTable.windows.restore(this.USERID, windowId);\n          } else {\n            await usersTable.windows.activate(this.USERID, windowId);\n          }\n          await usersTable.windows.reupdate(this.USERID);\n        } catch (error) {\n          console.error('Error restoring window:', error);\n        }\n      }\n    },\n    // Метод для показа ошибок\n    showError(message) {\n      console.error('App Error:', message);\n      // Можно добавить уведомление для пользователя\n      alert(message);\n    },\n    // открыть файл из IDB в конкретном приложении\n    async openFileApp(inpData) {\n      if (!this.USERID) throw new Error('User ID required');\n      if (!inpData) throw new Error('File data required');\n      console.log('||openFileApp (inpData):', inpData);\n      try {\n        const app = appsConfig.getAppById(inpData.app);\n\n        // Подготавливаем файл для сохранения\n        const preparedFile = this.prepareFileForWindow(inpData.file);\n        console.log('Prepared file:', preparedFile);\n\n        // Проверяем существующее окно\n        const existWindow_byConfig = await usersTable.windows.getWindow_byConfig(this.USERID, app);\n        if (existWindow_byConfig) {\n          console.log('Окно существует, активируем и обновляем файл');\n\n          // Получаем пользователя для обновления\n          const user = await usersTable.getbyId(this.USERID);\n          const windows = user?.systemconfig?.windows || [];\n\n          // Обновляем файл в существующем окне\n          const updatedWindows = windows.map(w => {\n            if (w.id === existWindow_byConfig.id) {\n              return {\n                ...w,\n                idbfile: preparedFile,\n                // Обновляем файл\n                isMinimized: false // Разворачиваем если свернуто\n              };\n            }\n            return w;\n          });\n\n          // Сохраняем обновленные окна\n          await usersTable.save({\n            ...user,\n            systemconfig: {\n              ...user.systemconfig,\n              windows: updatedWindows,\n              activeWindowId: existWindow_byConfig.id\n            }\n          });\n\n          // Активируем окно\n          await usersTable.windows.activate(this.USERID, existWindow_byConfig.id);\n        } else {\n          // Создаем новое окно с файлом\n          console.log('Создаем новое окно с файлом:', preparedFile);\n          await usersTable.windows.create(this.USERID, {\n            ...app,\n            idbfile: preparedFile,\n            isMinimized: false\n          });\n        }\n\n        // Обновляем список окон для синхронизации\n        await usersTable.windows.reupdate(this.USERID);\n      } catch (error) {\n        console.error('openFileApp:', error);\n        this.showError(`Error in openFileApp(): ${error.message}`);\n      }\n    },\n    // Вспомогательный метод для подготовки файла к сохранению\n    prepareFileForWindow(file) {\n      try {\n        // Если это Proxy, преобразуем в обычный объект\n        let plainFile = file;\n\n        // Проверяем, является ли объект Proxy\n        if (file && typeof file === 'object') {\n          // Пытаемся преобразовать в простой объект\n          try {\n            // Используем JSON для безопасной сериализации/десериализации\n            const jsonString = JSON.stringify(file, (key, value) => {\n              // Исключаем циклические ссылки и функции\n              if (key === 'blob' || key === '_objectUrl' || typeof value === 'function') {\n                return undefined;\n              }\n              return value;\n            });\n            plainFile = JSON.parse(jsonString);\n          } catch (e) {\n            console.warn('JSON serialization failed, using manual copy:', e);\n            // Если JSON.stringify не сработал, делаем ручное копирование\n            plainFile = {};\n            // Копируем только безопасные поля\n            const safeFields = ['id', 'name', 'type', 'size', 'mimetype', 'extension'];\n            safeFields.forEach(field => {\n              if (file[field] !== undefined) {\n                plainFile[field] = file[field];\n              }\n            });\n\n            // Копируем метаданные\n            if (file.metadata) {\n              plainFile.metadata = {};\n              const metaFields = ['duration', 'artist', 'album', 'title', 'width', 'height'];\n              metaFields.forEach(field => {\n                if (file.metadata[field] !== undefined) {\n                  plainFile.metadata[field] = file.metadata[field];\n                }\n              });\n            }\n          }\n        }\n\n        // Создаем безопасную копию только с нужными полями\n        const safeFile = {\n          id: plainFile.id || null,\n          name: plainFile.name || '',\n          type: plainFile.type || 'file',\n          size: plainFile.size || 0,\n          mimetype: plainFile.mimetype || '',\n          extension: plainFile.extension || '',\n          metadata: plainFile.metadata || {}\n        };\n\n        // Добавляем дополнительные поля из корневого объекта\n        const additionalFields = ['duration', 'artist', 'album', 'title', 'width', 'height'];\n        additionalFields.forEach(field => {\n          if (plainFile[field] !== undefined && !safeFile.metadata[field]) {\n            safeFile.metadata[field] = plainFile[field];\n          }\n        });\n        console.log('Prepared file for window:', safeFile);\n        return safeFile;\n      } catch (error) {\n        console.error('Error preparing file:', error);\n        // Возвращаем минимальный объект в случае ошибки\n        return {\n          id: null,\n          name: 'unknown',\n          type: 'file',\n          size: 0,\n          mimetype: '',\n          extension: '',\n          metadata: {}\n        };\n      }\n    }\n  }\n};","map":{"version":3,"names":["AutorizationArea","DesktopArea","TaskBar","SimpleWindow","usersTable","IDBWindows","activeWindowId","appsConfig","name","components","data","isAutorized","USERID","USER","computed","value","sortedWindows","visibleWindows","filter","w","isMinimized","sort","a","b","zIndex","methods","isActiveElem","windowId","closeWindow","closeComplWindow","windows","reupdate","error","console","minimizeWindow","minimize","toggleMaximizeWindow","window","find","id","isMaximized","user","getbyId","updatedWindows","map","save","systemconfig","activateWindow","activate","log","selectUser","userId","restoreWindow","restore","showError","message","alert","openFileApp","inpData","Error","app","getAppById","preparedFile","prepareFileForWindow","file","existWindow_byConfig","getWindow_byConfig","idbfile","create","plainFile","jsonString","JSON","stringify","key","undefined","parse","e","warn","safeFields","forEach","field","metadata","metaFields","safeFile","type","size","mimetype","extension","additionalFields"],"sources":["/home/kup/my_projects/vue/osi/src/App.vue"],"sourcesContent":["<template>\n    <AutorizationArea v-if=\"!isAutorized\" @selectUser=\"selectUser\" />\n    <div v-if=\"isAutorized\" class=\"webos\">\n        <DesktopArea :USERID=\"USERID\">\n            <SimpleWindow \n                v-for=\"window in sortedWindows\"\n                :key=\"window.id\"\n                :windowId=\"window.id\"\n                :title=\"window.label\"\n                :appName=\"window.name\"\n                :contentApp=\"window.contentApp\"\n                :icon=\"window.icon\"\n                :iconclass=\"window.iconclass\"\n                :defWidth=\"window.defWidth\"\n                :defHeight=\"window.defHeight\"\n                :isMinimized=\"window.isMinimized\"\n                :isActive=\"isActiveElem(window.id)\"\n                :isMaximized=\"window.isMaximized\"\n                :zIndex=\"window.zIndex\"\n                :resizable=\"window.resizable\"\n                :canMinimize=\"window.canMinimize\"\n                :USERID=\"USERID\"\n                :positionx=\"window.positionx\"\n                :positiony=\"window.positiony\"\n                :idbFile=\"window.idbfile\"\n                \n                @close=\"closeWindow\"\n                @minimize=\"minimizeWindow\"\n                @toggleMaximize=\"toggleMaximizeWindow\"\n                @focus=\"activateWindow\"\n                @mainopenfileapp=\"openFileApp\"\n            />\n        </DesktopArea>\n        <TaskBar :USERID=\"USERID\" />\n    </div>\n</template>\n<style src=\"./styles/global.css\"></style>\n<script>\nimport AutorizationArea from './components/os/AutorizationArea/AutorizationArea.vue';\nimport DesktopArea from './components/os/DesktopArea/DesktopArea.vue';\nimport TaskBar from './components/os/TaskBar/TaskBar.vue';\nimport SimpleWindow from './components/os/SimpleWindow/SimpleWindow.vue';\nimport { usersTable, IDBWindows, activeWindowId } from './idb/db';\nimport { appsConfig } from './config/applications';\n\nexport default {\n    name: 'App',\n\n    components: {\n        AutorizationArea,\n        DesktopArea,\n        TaskBar,\n        SimpleWindow\n    },\n\n    data() {\n        return {\n            isAutorized: false,\n            USERID: null,\n            USER: {},\n        }\n    },\n\n    computed: {\n        IDBWindows() { return IDBWindows.value; },\n        // Сортируем окна по zIndex для правильного отображения\n        sortedWindows() {\n            if (!this.IDBWindows) {\n                return [];\n            } else {\n                // Фильтруем свернутые окна - они не отображаются на рабочем столе\n                const visibleWindows = this.IDBWindows.filter(w => !w.isMinimized);            \n                // Сортируем по zIndex (от меньшего к большему)\n                return [...visibleWindows].sort((a, b) => (a.zIndex || 0) - (b.zIndex || 0));\n            }\n        },\n    },\n\n    methods: {\n        // проверка на \"это активный элемент\"\n        isActiveElem(windowId) { return windowId === activeWindowId.value; },\n\n        async closeWindow(windowId) {            \n            if (this.USERID && usersTable) {\n                try {\n                    await usersTable.closeComplWindow(this.USERID, windowId);\n                    await usersTable.windows.reupdate(this.USERID);\n                } catch (error) {\n                    console.error('Error closing window:', error);\n                }\n            }\n        },\n    \n        async minimizeWindow(windowId) {            \n            if (this.USERID && usersTable) {\n                try {\n                    await usersTable.windows.minimize(this.USERID, windowId);\n                    await usersTable.windows.reupdate(this.USERID);\n                } catch (error) {\n                    console.error('Error minimizing window:', error);\n                }\n            }\n        },\n    \n        async toggleMaximizeWindow(windowId) {            \n            if (this.USERID && usersTable) {\n                try {\n                    // Получаем текущее состояние окна\n                    const windows = IDBWindows.value || [];\n                    const window = windows.find(w => w.id === windowId);\n                    \n                    if (window) {\n                        // Переключаем состояние максимизации\n                        window.isMaximized = !window.isMaximized;\n                        \n                        // Обновляем в БД\n                        const user = await usersTable.getbyId(this.USERID);\n                        const updatedWindows = windows.map(w => \n                            w.id === windowId ? window : w\n                        );\n                        \n                        await usersTable.save({\n                            ...user,\n                            systemconfig: {\n                                ...user.systemconfig,\n                                windows: updatedWindows\n                            }\n                        });\n                        \n                        await usersTable.windows.reupdate(this.USERID);\n                    }\n                } catch (error) {\n                    console.error('Error toggling maximize window:', error);\n                }\n            }\n        },\n    \n        async activateWindow(windowId) {            \n            if (this.USERID && usersTable) { \n                try {\n                    // Активируем окно (обновляет zIndex и снимает свернутость)\n                    await usersTable.windows.activate(this.USERID, windowId);\n                    // Обновляем список окон\n                    await usersTable.windows.reupdate(this.USERID);\n                } catch (error) {\n                    console.error('Error activating window:', error);\n                }\n            } else {\n                console.log('Cannot activate: USERID or usersTable missing');\n            }\n        },\n\n        async selectUser(userId) {\n            this.USERID = userId;\n\n            if (usersTable) {\n                try {\n                    // Загружаем пользователя\n                    this.USER = await usersTable.getbyId(userId);\n                    // Обновляем список окон\n                    await usersTable.windows.reupdate(userId);\n                } catch (error) {\n                    console.error('Error loading user data:', error);\n                }\n            }\n            \n            this.isAutorized = true;\n        },\n\n        // Метод для восстановления окна из свернутого состояния\n        async restoreWindow(windowId) {            \n            if (this.USERID && usersTable) {\n                try {\n                    if (usersTable.windows.restore) {\n                        await usersTable.windows.restore(this.USERID, windowId);\n                    } else {\n                        await usersTable.windows.activate(this.USERID, windowId);\n                    }\n\n                    await usersTable.windows.reupdate(this.USERID);\n                } catch (error) {\n                    console.error('Error restoring window:', error);\n                }\n            }\n        },\n\n        // Метод для показа ошибок\n        showError(message) {\n            console.error('App Error:', message);\n            // Можно добавить уведомление для пользователя\n            alert(message);\n        },\n\n        // открыть файл из IDB в конкретном приложении\n        async openFileApp(inpData) {\n            if (!this.USERID) throw new Error('User ID required');\n            if (!inpData) throw new Error('File data required');\n\n            console.log('||openFileApp (inpData):', inpData);\n            try {\n                const app = appsConfig.getAppById(inpData.app);\n                \n                // Подготавливаем файл для сохранения\n                const preparedFile = this.prepareFileForWindow(inpData.file);\n                console.log('Prepared file:', preparedFile);\n                \n                // Проверяем существующее окно\n                const existWindow_byConfig = await usersTable.windows.getWindow_byConfig(this.USERID, app);\n                \n                if (existWindow_byConfig) {\n                    console.log('Окно существует, активируем и обновляем файл');\n                    \n                    // Получаем пользователя для обновления\n                    const user = await usersTable.getbyId(this.USERID);\n                    const windows = user?.systemconfig?.windows || [];\n                    \n                    // Обновляем файл в существующем окне\n                    const updatedWindows = windows.map(w => {\n                        if (w.id === existWindow_byConfig.id) {\n                            return {\n                                ...w,\n                                idbfile: preparedFile, // Обновляем файл\n                                isMinimized: false // Разворачиваем если свернуто\n                            };\n                        }\n                        return w;\n                    });\n                    \n                    // Сохраняем обновленные окна\n                    await usersTable.save({\n                        ...user,\n                        systemconfig: {\n                            ...user.systemconfig,\n                            windows: updatedWindows,\n                            activeWindowId: existWindow_byConfig.id\n                        }\n                    });\n                    \n                    // Активируем окно\n                    await usersTable.windows.activate(this.USERID, existWindow_byConfig.id);\n                    \n                } else {\n                    // Создаем новое окно с файлом\n                    console.log('Создаем новое окно с файлом:', preparedFile);\n                    \n                    await usersTable.windows.create(this.USERID, { \n                        ...app,\n                        idbfile: preparedFile,\n                        isMinimized: false\n                    });\n                }\n                \n                // Обновляем список окон для синхронизации\n                await usersTable.windows.reupdate(this.USERID);\n                \n            } catch (error) {\n                console.error('openFileApp:', error);\n                this.showError(`Error in openFileApp(): ${error.message}`);\n            }\n        },\n\n        // Вспомогательный метод для подготовки файла к сохранению\n        prepareFileForWindow(file) {\n            try {\n                // Если это Proxy, преобразуем в обычный объект\n                let plainFile = file;\n                \n                // Проверяем, является ли объект Proxy\n                if (file && typeof file === 'object') {\n                    // Пытаемся преобразовать в простой объект\n                    try {\n                        // Используем JSON для безопасной сериализации/десериализации\n                        const jsonString = JSON.stringify(file, (key, value) => {\n                            // Исключаем циклические ссылки и функции\n                            if (key === 'blob' || key === '_objectUrl' || typeof value === 'function') {\n                                return undefined;\n                            }\n                            return value;\n                        });\n                        plainFile = JSON.parse(jsonString);\n                    } catch (e) {\n                        console.warn('JSON serialization failed, using manual copy:', e);\n                        // Если JSON.stringify не сработал, делаем ручное копирование\n                        plainFile = {};\n                        // Копируем только безопасные поля\n                        const safeFields = ['id', 'name', 'type', 'size', 'mimetype', 'extension'];\n                        safeFields.forEach(field => {\n                            if (file[field] !== undefined) {\n                                plainFile[field] = file[field];\n                            }\n                        });\n                        \n                        // Копируем метаданные\n                        if (file.metadata) {\n                            plainFile.metadata = {};\n                            const metaFields = ['duration', 'artist', 'album', 'title', 'width', 'height'];\n                            metaFields.forEach(field => {\n                                if (file.metadata[field] !== undefined) {\n                                    plainFile.metadata[field] = file.metadata[field];\n                                }\n                            });\n                        }\n                    }\n                }\n                \n                // Создаем безопасную копию только с нужными полями\n                const safeFile = {\n                    id: plainFile.id || null,\n                    name: plainFile.name || '',\n                    type: plainFile.type || 'file',\n                    size: plainFile.size || 0,\n                    mimetype: plainFile.mimetype || '',\n                    extension: plainFile.extension || '',\n                    metadata: plainFile.metadata || {}\n                };\n                \n                // Добавляем дополнительные поля из корневого объекта\n                const additionalFields = ['duration', 'artist', 'album', 'title', 'width', 'height'];\n                additionalFields.forEach(field => {\n                    if (plainFile[field] !== undefined && !safeFile.metadata[field]) {\n                        safeFile.metadata[field] = plainFile[field];\n                    }\n                });\n                \n                console.log('Prepared file for window:', safeFile);\n                return safeFile;\n                \n            } catch (error) {\n                console.error('Error preparing file:', error);\n                // Возвращаем минимальный объект в случае ошибки\n                return {\n                    id: null,\n                    name: 'unknown',\n                    type: 'file',\n                    size: 0,\n                    mimetype: '',\n                    extension: '',\n                    metadata: {}\n                };\n            }\n        },\n    },\n}\n</script>\n\n<style>\n.webos {\n    width: 100vw;\n    height: 100vh;\n    overflow: hidden;\n    position: relative;\n    background: #1a1a1a;\n}\n</style>