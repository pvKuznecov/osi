{"ast":null,"code":"import { usersTable } from '@/idb/db';\nconst BaseIcon = '/src/assets/icons/favicons/icon_big.png';\nexport default {\n  name: 'NotificationsArea',\n  props: {\n    USERID: {\n      type: Number,\n      default: 0\n    }\n  },\n  data() {\n    return {\n      USER: null,\n      UserLang: null,\n      osiIcon: BaseIcon,\n      AllNotifs: [],\n      fullModeNotif: null\n    };\n  },\n  computed: {\n    unreadCount() {\n      return this.AllNotifs.length;\n    }\n  },\n  methods: {\n    async findUser() {\n      try {\n        this.USER = await usersTable.getbyId(this.USERID);\n        if (this.USER) this.getAllNotifs();\n      } catch (error) {\n        console.error('Ошибка поиска пользователя:', error);\n        this.$toast.error('Не удалось загрузить данные пользователя');\n      }\n    },\n    async getAllNotifs() {\n      try {\n        const resArr = await usersTable.notifs.getAll(this.USERID);\n        this.AllNotifs = resArr;\n      } catch (err) {\n        console.error('[FUNC ERR] getAllNotifs::', err);\n      }\n    },\n    SelectedNotif(notif = false) {\n      this.fullModeNotif = !notif ? null : notif;\n    }\n  },\n  async mounted() {\n    const userLang = navigator.language || navigator.userLanguage;\n    const userLangS = userLang.split('-')[0];\n    this.UserLang = userLangS;\n    this.findUser();\n  }\n};","map":{"version":3,"names":["usersTable","BaseIcon","name","props","USERID","type","Number","default","data","USER","UserLang","osiIcon","AllNotifs","fullModeNotif","computed","unreadCount","length","methods","findUser","getbyId","getAllNotifs","error","console","$toast","resArr","notifs","getAll","err","SelectedNotif","notif","mounted","userLang","navigator","language","userLanguage","userLangS","split"],"sources":["/home/kup/my_projects/vue/osi/src/components/os/NotificationsArea/NotificationsArea.vue"],"sourcesContent":["<!-- <template src=\"./template.html\"></template> -->\n <!-- <style src=\"./style.css\"></style> -->\n<template>\n    <div class=\"notifs-area\">\n        <div v-for=\"notif in AllNotifs\" :class=\"(notif !== fullModeNotif) ? 'notifelem_minimal' : 'notifelem'\" :id=\"`notif_${notif.id}`\">\n            <!-- Блок \"мини\" отображения -->\n            <div v-if=\"notif !== fullModeNotif\" class=\"minelem_content\" @click=\"SelectedNotif(notif)\">\n                <div class=\"logo\">{{notif.app ?? 'OSI'}}</div>\n                <div>{{notif.title}}</div>\n                <div class=\"elem_content_btn_close bi bi-x-lg\"></div>\n            </div>\n            <!-- Блок \"полного\" отображения -->\n            <div v-else class=\"elem_content\">\n                <div class=\"title\">\n                    <div class=\"logo\">{{notif.app ?? 'OSI'}}</div>\n                    {{notif.title}}\n                    <div class=\"elem_content_btn_close bi bi-x-lg\"></div>\n                </div>\n                <!-- <div v-html=\"notif.content\" class=\"content\"></div> -->\n                <div class=\"content\">{{notif}}</div>\n                <div class=\"create_time\"><span>От: {{notif.createdAt.toLocaleString('ru-RU')}}</span></div>\n            </div>\n        </div>\n    </div>\n</template>\n<style>\n.notifs-area {\n    display: flex;\n    flex-direction: column;\n    justify-content: flex-end;\n    position: absolute;\n    min-width: 600px;\n    max-width: 600px;\n    float: right;\n    top: 0;\n    right: 0;\n    /* padding: 5px 10px; */\n    bottom: 40px;\n    z-index: 5000;\n    /* background-color: rgba(240, 248, 255, 0.2); */\n    overflow: hidden;\n    overflow-y: auto; }\n\n@keyframes slideInRight {\n    from {\n        transform: translateX(100%);\n        opacity: 0;\n    }\n    to {\n        transform: translateX(0);\n        opacity: 1;\n    }\n}\n.notifelem {\n    display: block;\n    width: calc(98% - 10px);\n    /* height: 150px; */\n    margin-left: auto;\n    margin-right: auto;\n    margin-bottom: 10px;\n    padding: 5px;\n    font-size: medium;\n    border-radius: 5px; }\n\n.notifelem_minimal {\n    display: block;\n    min-width: calc(48% - 10px);\n    max-width: calc(98% - 10px);\n    height: 40px;\n    margin-left: auto;\n    margin-right: 1%;\n    margin-bottom: 5px;\n    border-radius: 5px;\n    cursor: pointer;\n    background: linear-gradient(rgba(0, 0, 0, 0.85), rgba(0, 0, 0, 0.8), rgba(0, 0, 0, 0.85));\n    animation: slideInRight 0.5s ease forwards;\n}\n.notifelem_minimal:hover { box-shadow: 1px 3px 5px rgba(58, 53, 70, 0.6); margin-right: 10px; }\n\n.elem_content {\n    display: flex;\n    flex-direction: column;\n    border-radius: 5px; }\n\n.minelem_content {\n    display: flex;\n    flex-direction: row;\n    align-items: center;\n    justify-content: space-between;\n    width: 100%;\n    height: 100%;\n    background: linear-gradient(to bottom, rgb(103, 55, 235), rgb(80, 33, 209));\n    color: white;\n    font-weight: 600;\n    border-radius: 5px;\n    padding: 0 5px; }\n\n.elem_content_btn_close {\n    display: flex;\n    cursor: pointer;\n    align-items: center;\n    justify-content: center;\n    width: 18px;\n    height: 18px;\n    font-size: 12px;\n    border-radius: 5px; }\n.elem_content_btn_close:hover {box-shadow: 1px 1px black; background-color: #e81123; }\n\n.minelem_content .logo {\n    display: flex;\n    flex-direction: column;\n    align-content: center;\n    justify-content: space-around;\n    width: 30px;\n    height: 30px;\n    background-color: white;\n    border-radius: 5px;\n    font-size: small;\n    text-align: center;\n    color: black; }\n\n.elem_content .title {\n    display: flex;\n    flex-direction: row;\n    width: 100%;\n    align-items: center;\n    justify-content: space-between;\n    color: white;\n    padding: 0 5px;\n    border: 1px solid rgb(80, 33, 209);\n    background: linear-gradient(to bottom, rgb(103, 55, 235), rgb(80, 33, 209));\n    border-radius: 5px 5px 0 0; }\n\n.elem_content .content {\n    width: 100%;\n    border: 1px solid rgb(80, 33, 209);\n    border-radius: 0 0 5px 5px;\n    color: white;\n    font-size: small;\n    background: linear-gradient(rgba(0, 0, 0, 0.85), rgba(0, 0, 0, 0.8), rgba(0, 0, 0, 0.85));\n    padding: 10px 10px 5px 10px; }\n\n.create_time {\n    display: block;\n    font-size: small;\n    text-align: right;\n    color: white; }\n\n.create_time span {\n    padding: 2px 5px;\n    background: linear-gradient(rgba(0, 0, 0, 0.85), rgba(0, 0, 0, 0.8), rgba(0, 0, 0, 0.85));\n    border-radius: 5px; }\n</style>\n<script>\n    import { usersTable } from '@/idb/db';\n\n    const BaseIcon = '/src/assets/icons/favicons/icon_big.png';\n\n    export default {\n        name: 'NotificationsArea',\n\n        props: {\n            USERID: {type: Number, default: 0}\n        },\n  \n        data() {\n            return {\n                USER: null,\n                UserLang: null,\n                osiIcon: BaseIcon,\n\n                AllNotifs: [],\n\n                fullModeNotif: null,\n            }\n        },\n\n        computed: {\n            unreadCount() {\n                return this.AllNotifs.length;\n            }\n        },\n\n        methods: {\n            async findUser() {\n                try {                    \n                    this.USER = await usersTable.getbyId(this.USERID);\n\n                    if (this.USER) this.getAllNotifs();\n                } catch (error) {\n                    console.error('Ошибка поиска пользователя:', error);\n                    this.$toast.error('Не удалось загрузить данные пользователя');\n                }\n            },\n\n            async getAllNotifs() {\n                try {\n                    const resArr = await usersTable.notifs.getAll(this.USERID);\n                    \n                    this.AllNotifs = resArr;\n                } catch (err) {\n                    console.error('[FUNC ERR] getAllNotifs::', err);\n                }                \n            },\n\n            SelectedNotif(notif = false) {\n                this.fullModeNotif = (!notif) ? null : notif;\n            },\n        },\n        \n        async mounted() {\n            const userLang = navigator.language || navigator.userLanguage;\n            const userLangS = userLang.split('-')[0];\n            this.UserLang = userLangS;\n\n            this.findUser();\n        },\n    }\n</script>"],"mappings":"AA0JI,SAASA,UAAS,QAAS,UAAU;AAErC,MAAMC,QAAO,GAAI,yCAAyC;AAE1D,eAAe;EACXC,IAAI,EAAE,mBAAmB;EAEzBC,KAAK,EAAE;IACHC,MAAM,EAAE;MAACC,IAAI,EAAEC,MAAM;MAAEC,OAAO,EAAE;IAAC;EACrC,CAAC;EAEDC,IAAIA,CAAA,EAAG;IACH,OAAO;MACHC,IAAI,EAAE,IAAI;MACVC,QAAQ,EAAE,IAAI;MACdC,OAAO,EAAEV,QAAQ;MAEjBW,SAAS,EAAE,EAAE;MAEbC,aAAa,EAAE;IACnB;EACJ,CAAC;EAEDC,QAAQ,EAAE;IACNC,WAAWA,CAAA,EAAG;MACV,OAAO,IAAI,CAACH,SAAS,CAACI,MAAM;IAChC;EACJ,CAAC;EAEDC,OAAO,EAAE;IACL,MAAMC,QAAQA,CAAA,EAAG;MACb,IAAI;QACA,IAAI,CAACT,IAAG,GAAI,MAAMT,UAAU,CAACmB,OAAO,CAAC,IAAI,CAACf,MAAM,CAAC;QAEjD,IAAI,IAAI,CAACK,IAAI,EAAE,IAAI,CAACW,YAAY,CAAC,CAAC;MACtC,EAAE,OAAOC,KAAK,EAAE;QACZC,OAAO,CAACD,KAAK,CAAC,6BAA6B,EAAEA,KAAK,CAAC;QACnD,IAAI,CAACE,MAAM,CAACF,KAAK,CAAC,0CAA0C,CAAC;MACjE;IACJ,CAAC;IAED,MAAMD,YAAYA,CAAA,EAAG;MACjB,IAAI;QACA,MAAMI,MAAK,GAAI,MAAMxB,UAAU,CAACyB,MAAM,CAACC,MAAM,CAAC,IAAI,CAACtB,MAAM,CAAC;QAE1D,IAAI,CAACQ,SAAQ,GAAIY,MAAM;MAC3B,EAAE,OAAOG,GAAG,EAAE;QACVL,OAAO,CAACD,KAAK,CAAC,2BAA2B,EAAEM,GAAG,CAAC;MACnD;IACJ,CAAC;IAEDC,aAAaA,CAACC,KAAI,GAAI,KAAK,EAAE;MACzB,IAAI,CAAChB,aAAY,GAAK,CAACgB,KAAK,GAAI,IAAG,GAAIA,KAAK;IAChD;EACJ,CAAC;EAED,MAAMC,OAAOA,CAAA,EAAG;IACZ,MAAMC,QAAO,GAAIC,SAAS,CAACC,QAAO,IAAKD,SAAS,CAACE,YAAY;IAC7D,MAAMC,SAAQ,GAAIJ,QAAQ,CAACK,KAAK,CAAC,GAAG,CAAC,CAAC,CAAC,CAAC;IACxC,IAAI,CAAC1B,QAAO,GAAIyB,SAAS;IAEzB,IAAI,CAACjB,QAAQ,CAAC,CAAC;EACnB;AACJ","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}