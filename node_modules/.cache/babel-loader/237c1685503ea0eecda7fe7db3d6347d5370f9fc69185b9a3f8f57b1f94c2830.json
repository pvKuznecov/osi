{"ast":null,"code":"export default {\n  name: 'AppIcon',\n  props: {\n    iconImg: {\n      type: [String, Object],\n      default: ''\n    },\n    iconclass: {\n      type: String,\n      default: ''\n    },\n    icon: {\n      type: String,\n      default: ''\n    },\n    alt: {\n      type: String,\n      default: ''\n    },\n    size: {\n      type: String,\n      default: 'md'\n    }\n  },\n  computed: {\n    sizeClass() {\n      return `app-icon--${this.size}`;\n    }\n  }\n};","map":{"version":3,"names":["name","props","iconImg","type","String","Object","default","iconclass","icon","alt","size","computed","sizeClass"],"sources":["/home/kup/my_projects/vue/osi/src/components/os/AppIcon/AppIcon.vue"],"sourcesContent":["<template>\n    <img\n        v-if=\"iconImg\"\n        :src=\"iconImg\"\n        :alt=\"alt\"\n        class=\"app-icon-img\"\n        :class=\"sizeClass\"\n    />\n    <!-- Старый подход: Bootstrap Icons + CSS-градиент (iconclass) -->\n    <div\n        v-else-if=\"iconclass\"\n        class=\"app-icon-css\"\n        :class=\"[sizeClass, iconclass]\"\n        :style=\"{ color: 'white' }\"\n    ></div>\n    <span v-else-if=\"icon\" class=\"app-icon-emoji\" :class=\"sizeClass\">{{ icon }}</span>\n</template>\n\n<style src=\"./style.css\"></style>\n\n<script>\n    export default {\n        name: 'AppIcon',\n\n        props: {\n            iconImg: { type: [String, Object], default: '' },\n            iconclass: { type: String, default: '' },\n            icon: { type: String, default: '' },\n            alt: { type: String, default: '' },\n            size: { type: String, default: 'md' },\n        },\n\n        computed: {\n            sizeClass() {\n                return `app-icon--${this.size}`;\n            },\n        },\n    };\n</script>\n"],"mappings":"AAqBI,eAAe;EACXA,IAAI,EAAE,SAAS;EAEfC,KAAK,EAAE;IACHC,OAAO,EAAE;MAAEC,IAAI,EAAE,CAACC,MAAM,EAAEC,MAAM,CAAC;MAAEC,OAAO,EAAE;IAAG,CAAC;IAChDC,SAAS,EAAE;MAAEJ,IAAI,EAAEC,MAAM;MAAEE,OAAO,EAAE;I